class Solution {
    public int kthGrammar(int n, int k) {
        // Base case: the first row is always 0
        if (n == 1) {
            return 0;
        }

        // Calculate the length of the previous row (the midpoint)
        // Using Math.pow or bit shifting (1 << (n-2))
        long mid = (long) Math.pow(2, n - 2);

        if (k <= mid) {
            // k is in the first half, so it's the same as row n-1
            return kthGrammar(n - 1, k);
        } else {
            // k is in the second half, so it's the inverse of row n-1
            // We find the corresponding position in the first half (k - mid)
            // and return the flipped value (1 - result)
            return 1 - kthGrammar(n - 1, (int)(k - mid));
        }
    }
}

