class Solution {
    public int missingNumber(int[] nums) {
        int n = nums.length;
        int xor = n; // Start with n because the loop only goes up to n-1
        
        for (int i = 0; i < n; i++) {
            // XOR current index and current value
            xor ^= i ^ nums[i];
        }
        
        return xor;
    }
}
