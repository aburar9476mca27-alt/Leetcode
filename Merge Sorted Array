class Solution {
    public void merge(int[] nums1, int m, int[] nums2, int n) {
        // Pointers for the end of the actual elements in nums1 and nums2
        int p1 = m - 1;
        int p2 = n - 1;
        // Pointer for the very last position in nums1
        int pSorted = m + n - 1;

        // While there are elements to compare in both arrays
        while (p2 >= 0) {
            // If p1 is still valid and nums1 element is bigger, move it to the back
            if (p1 >= 0 && nums1[p1] > nums2[p2]) {
                nums1[pSorted] = nums1[p1];
                p1--;
            } else {
                // Otherwise, nums2 element is bigger (or p1 is exhausted)
                nums1[pSorted] = nums2[p2];
                p2--;
            }
            pSorted--;
        }
    }
}
