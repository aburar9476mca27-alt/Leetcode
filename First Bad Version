/* The isBadVersion API is defined in the parent class VersionControl.
      boolean isBadVersion(int version); */

public class Solution extends VersionControl {
    public int firstBadVersion(int n) {
        int left = 1;
        int right = n;
        
        while (left < right) {
            // Use (right - left) / 2 + left to prevent potential integer overflow
            int mid = left + (right - left) / 2;
            
            if (isBadVersion(mid)) {
                // If mid is bad, the first bad version is either mid or to its left
                right = mid;
            } else {
                // If mid is good, the first bad version must be to its right
                left = mid + 1;
            }
        }
        
        // After the loop, left == right, which is the first bad version
        return left;
    }
}
