class Solution {
    public int countPrimes(int n) {
        // Base case: there are no primes less than 2
        if (n <= 2) {
            return 0;
        }

        // isPrime[i] will be true if i is a prime number
        boolean[] isPrime = new boolean[n];
        // Initialize all entries as true from index 2 to n-1
        for (int i = 2; i < n; i++) {
            isPrime[i] = true;
        }

        // Sieve of Eratosthenes
        for (int p = 2; p * p < n; p++) {
            // If isPrime[p] is not changed, then it is a prime
            if (isPrime[p]) {
                // Update all multiples of p starting from p*p
                // Numbers less than p*p would have already been marked by smaller primes
                for (int i = p * p; i < n; i += p) {
                    isPrime[i] = false;
                }
            }
        }

        // Count the remaining true values
        int count = 0;
        for (int i = 2; i < n; i++) {
            if (isPrime[i]) {
                count++;
            }
        }

        return count;
    }
}
