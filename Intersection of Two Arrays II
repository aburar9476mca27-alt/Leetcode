class Solution {
    public int[] intersect(int[] nums1, int[] nums2) {
        // Use a HashMap to store frequencies of numbers in the first array
        Map<Integer, Integer> map = new HashMap<>();
        for (int num : nums1) {
            map.put(num, map.getOrDefault(num, 0) + 1);
        }

        List<Integer> result = new ArrayList<>();
        for (int num : nums2) {
            // If the number exists in the map and has a count > 0, it's an intersection
            if (map.containsKey(num) && map.get(num) > 0) {
                result.add(num);
                // Reduce the count in the map to handle duplicates correctly
                map.put(num, map.get(num) - 1);
            }
        }

        // Convert the List back to a primitive int array
        int[] output = new int[result.size()];
        for (int i = 0; i < result.size(); i++) {
            output[i] = result.get(i);
        }
        return output;   
    }
}
