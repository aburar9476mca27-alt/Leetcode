class Solution {
    public boolean isSymmetric(TreeNode root) { // Fixed parameter type
        if (root == null) return true;
        
        Queue<TreeNode> q = new LinkedList<>();
        q.add(root.left);
        q.add(root.right);
        
        while (!q.isEmpty()) {
            TreeNode t1 = q.poll();
            TreeNode t2 = q.poll();
            
            // If both are null, they match; continue to next pair
            if (t1 == null && t2 == null) continue;
            
            // If one is null or values don't match, it's not symmetric
            if (t1 == null || t2 == null || t1.val != t2.val) return false;
            
            // Add children in mirror order for the next comparison
            q.add(t1.left);
            q.add(t2.right);
            q.add(t1.right);
            q.add(t2.left);
        }
        return true;
    }
}
